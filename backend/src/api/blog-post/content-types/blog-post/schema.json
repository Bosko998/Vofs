{
  "kind": "collectionType",
  "collectionName": "blog_posts",
  "info": {
    "singularName": "blog-post",
    "pluralName": "blog-posts",
    "displayName": "Blog Post"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "rating": {
      "type": "integer",
      "required": true,
      "max": 10,
      "min": 1
    },
    "body": {
      "type": "richtext",
      "required": true
    }
  }
}
